{
    "name": "linkplaces",
    "private": true,
    "type": "module",
    "license": "MPL-2.0",
    "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
    "devDependencies": {
        "@ava/typescript": "catalog:",
        "@babel/plugin-syntax-jsx": "catalog:",
        "@linkplaces/eslint_config": "workspace:*",
        "@linkplaces/tools": "workspace:*",
        "@monorepo-utils/workspaces-to-typescript-project-references": "catalog:",
        "@reflink/reflink": "catalog:",
        "@typescript/native-preview": "catalog:",
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "ava": "catalog:",
        "babel-plugin-react-compiler": "catalog:",
        "eslint": "catalog:",
        "globals": "catalog:",
        "prettier": "catalog:",
        "tinyspy": "catalog:",
        "turbo": "catalog:",
        "web-ext": "catalog:"
    },
    "scripts": {
        "clean:package": "node ./tools/rm_dir.js ./web-ext-artifacts/ --verbose",
        "typecheck": "tsgo --build --emitDeclarationOnly",
        "format": "node --run __format -- --write",
        "format:check": "node --run __format -- --check",
        "__format": "prettier '**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts,css,yaml,yml}'",
        "build": "tsgo --build",
        "build:package": "web-ext build -s ./packages/linkplaces/__dist/ --artifacts-dir ./web-ext-artifacts",
        "check:relationship_between_workspace_and_ts_pj_reference": "workspaces-to-typescript-project-references --check",
        "eslint": "eslint '.'"
    }
}
